set selection-clipboard clipboard
set window-title-home-tilde true
set statusbar-home-tilde true
set adjust-open "best-fit"

# Notifications
set notification-error-bg       "#ED333B"
set notification-error-fg       "#FFFFFF"

set notification-warning-bg     "#F6D32D"
set notification-warning-fg     "#1D1D20"

set notification-bg             "#242428"
set notification-fg             "#F6F5F4"

# Completion
set completion-bg               "#1D1D20"
set completion-fg               "#9A9996"

set completion-group-bg         "#1D1D20"
set completion-group-fg         "#62A0EA"

set completion-highlight-bg     "#2E2E32"
set completion-highlight-fg     "#FFFFFF"

# Index
set index-bg                    "#1D1D20"
set index-fg                    "#F6F5F4"

set index-active-bg             "#2E2E32"
set index-active-fg             "#62A0EA"

# Bars
set inputbar-bg                 "#1D1D20"
set inputbar-fg                 "#F6F5F4"

set statusbar-bg                "#1D1D20"
set statusbar-fg                "#C0BFBC"

# Highlights
set highlight-color             "#33B2A4"
set highlight-active-color      "#62A0EA"

# Document colors
set default-bg                  "#1D1D20"
set default-fg                  "#F6F5F4"

# Loading
set render-loading              true
set render-loading-fg           "#1D1D20"
set render-loading-bg           "#62A0EA"

# Recolor mode
set recolor-lightcolor          "#1D1D20"
set recolor-darkcolor           "#F6F5F4"

# Startup
set adjust-open width
map <C-Tab> toggle_statusbar
set guioptions ""
